    {
      "name": "CampFireVRChat",
      "url": "https://camp-fire.jp/projects/search?word=VRChat",
      "handler": "general",
      "rss_items": 30,
      "interval_sec": 43200,
      "include_regex": [
        "^https://camp-fire\\.jp/projects/\\d+(/view)?(?:\\?.*)?$",
        "^https://camp-fire\\.jp/projects/view/\\d+(?:\\?.*)?$"
      ],
      "exclude_regex": [
        "^https://camp-fire\\.jp/$",
        "^https://camp-fire\\.jp/projects/(?:search|category)(?:\\?.*)?$",
        "^https://camp-fire\\.jp/(?:project_rewards|creation|furusato|forsocialgood|machi-ya)(?:/|\\?.*)?$",
        "^https://camp-fire\\.jp/(?:help|academy|community|channels|company|privacy|term|news|lp)(?:/|\\?.*)?$",
        "\\?token="
      ]
    },
    {
      "name": "LRCHub-PR",
      "url": "https://api.github.com/search/issues?q=org%3ALRCHub+is%3Apr+is%3Aopen&sort=created&order=desc&per_page=50",
      "handler": "github_search",
      "rss_items": 50,
      "interval_sec": 300,
      "user_agent": "SiteRSSBot (LRCHub PR monitor)",
      "include_regex": [
        "^https://github\\.com/LRCHub/[^/]+/pull/\\d+$"
      ],
      "exclude_regex": [
        "^https://api\\.github\\.com/"
      ],
