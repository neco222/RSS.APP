{
  "github": {
    "token_env": "GITHUB_TOKEN",
    "repo": "${GITHUB_REPOSITORY}",
    "branch": "main"
  },
  "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/119.0.0.0 Safari/537.36",
  "rss_items_default": 0,
  "site_interval_default": 60,
  "site_manifest_path": "Site.json",
  "site_manifest_ttl_sec": 200,
  "poll_interval_sec": 60,
  "rss_output_dir": "RSS",
  "readme_path": "RSS/README.md",
  "readme_log_header": "## Update log\n",
  "state_path": "RSS/state.json",
  "daily_flag_path": "RSS/00.txt"
}